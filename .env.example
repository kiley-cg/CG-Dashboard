# =============================================================================
# CG-Dashboard / Syncore AI Pricing Agent — Environment Variables
# Copy this file to .env.local for local development.
# In production, values are injected via apphosting.yaml + Google Cloud Secret Manager.
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Syncore CRM ---
SYNCORE_API_KEY=

# --- Firebase / Firestore (pricing matrices + agent memory) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key including the -----BEGIN/END----- lines.
# Vercel stores multi-line values correctly; locally use literal \n or a multi-line value.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# --- SanMar SOAP API ---
SANMAR_API_USER=
SANMAR_API_PASSWORD=
SANMAR_PRICING_WSDL=https://ws.sanmar.com:8080/SanMarWebService/SanMarPricingServicePort?wsdl

# --- S&S Activewear REST API ---
SS_CUSTOMER_NUMBER=
SS_API_KEY=
SS_API_BASE_URL=https://api.ssactivewear.com/v2

# --- NextAuth / Google OAuth ---
# Set AUTH_SECRET to a random 32-char string: `openssl rand -base64 32`
AUTH_SECRET=
# Set to your deployed URL in production.
# Firebase App Hosting format: https://<BACKEND_ID>--<PROJECT_ID>.us-central1.hosted.app
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only users with this email domain can sign in
ALLOWED_DOMAIN=colorgraphicswa.com

# --- Chrome Extension ---
# A secret shared between the extension and the server for API-key auth.
# Generate something strong: `openssl rand -hex 32`
EXTENSION_API_KEY=
