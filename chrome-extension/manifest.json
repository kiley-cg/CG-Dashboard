{
  "manifest_version": 3,
  "name": "CG Pricing Agent",
  "version": "2.1",
  "description": "AI pricing assistant side panel for Syncore sales orders",
  "permissions": ["storage", "activeTab", "tabs", "sidePanel"],
  "host_permissions": [
    "*://app.syncore.app/*",
    "*://*.syncore.app/*",
    "*://*.ateasesystems.net/*",
    "http://localhost:*/*",
    "https://*.hosted.app/*",
    "https://*.run.app/*",
    "https://cg-dashboard-ai.netlify.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://app.syncore.app/*", "*://*.syncore.app/*", "*://*.ateasesystems.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "action": {
    "default_title": "CG Pricing Agent"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
