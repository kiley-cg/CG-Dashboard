{
  "manifest_version": 3,
  "name": "CG Pricing Agent",
  "version": "1.0",
  "description": "AI pricing assistant overlay for Syncore sales orders",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://app.syncore.app/*", "*://*.syncore.app/*", "*://*.ateasesystems.net/*"],
  "content_scripts": [
    {
      "matches": ["*://app.syncore.app/*", "*://*.syncore.app/*", "*://*.ateasesystems.net/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CG Pricing Agent"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
